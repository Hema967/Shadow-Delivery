### Shadow – Fast Grocery Delivery (example)
COMPOSE_PROJECT_NAME=shadow

# App
JWT_SECRET=replace_me_with_strong_secret
API_BASE_URL=http://localhost:4000
FRONTEND_BASE_URL=http://localhost:3000

# Mongo
MONGO_INITDB_ROOT_USERNAME=shadow
MONGO_INITDB_ROOT_PASSWORD=shadowpassword
MONGODB_DATABASE=shadow

# Redis
REDIS_URL=redis://redis:6379

# CORS (backend)
CORS_ORIGIN=http://localhost:3000

